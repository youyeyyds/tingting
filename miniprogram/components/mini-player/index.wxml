<!--mini-player/index.wxml-->
<view wx:if="{{visible && !showPlayerPanel}}" class="mini-player {{fadeInClass}}" style="bottom: {{playerBottom}}px;" catchtouchmove="preventMove">
  <!-- 左边可点击区域：封面和信息 -->
  <view class="left-area" bindtap="openPlayerPanel">
    <!-- 封面 -->
    <image class="chapter-cover" src="{{courseCover}}" mode="aspectFill" />

    <!-- 信息 -->
    <view class="chapter-info">
      <view class="chapter-title">{{currentChapter.title}}</view>
      <view class="chapter-meta">
        <text class="course-name">{{courseName}}</text>
        <text class="dot">·</text>
        <text class="chapter-seq">第{{currentChapter.seq}}章</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <!-- 播放列表 -->
    <view class="playlist-btn" catchtap="onPlaylistTap">
      <view class="playlist-icon">
        <view class="playlist-line"></view>
        <view class="playlist-line"></view>
        <view class="playlist-line"></view>
      </view>
    </view>

    <!-- 倍速 -->
    <view class="speed-btn" catchtap="onSpeedChange">
      <text class="speed-text">{{playbackRate}}x</text>
    </view>

    <!-- 播放/暂停 -->
    <view class="play-btn" catchtap="onPlayPause">
      <view class="play-icon {{isPlaying ? 'pause' : ''}}">
        <view class="pause-bar" wx:if="{{isPlaying}}"></view>
        <view class="pause-bar" wx:if="{{isPlaying}}"></view>
      </view>
    </view>

    <!-- 关闭 -->
    <view class="close-btn" catchtap="onClose">
      <text class="close-text">×</text>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
  </view>
</view>

<!-- 播放列表面板 -->
<playlist-panel id="playlistPanel" chapters="{{chapters}}" course="{{course}}" currentIndex="{{currentIndex}}" currentChapterId="{{currentChapter._id || ''}}" initialSortOrder="{{playlistSortOrder}}" isFavoriteList="{{isFavoriteList}}"
                bind:play="onPlaylistPlay" bind:togglePlayPause="togglePlayPause" bind:delete="onPlaylistDelete" bind:collapse="onPlaylistCollapse" bind:clear="onPlaylistClear" bind:syncSort="onPlaylistSyncSort" />

<!-- 播放器面板（page-container 原生动画） -->
<page-container show="{{showPlayerPanel}}" position="bottom" overlay="{{false}}" bind:afterleave="onPlayerPanelLeave">
  <view class="player-container">
    <!-- 收起按钮（向下箭头） -->
    <view class="header-area" bindtap="closePlayerPanel">
      <view class="collapse-icon"></view>
    </view>

    <!-- 封面图 -->
    <view class="cover-section">
      <image class="cover-image {{isPlaying ? 'playing' : ''}}" style="transform: rotate({{coverRotationAngle}}deg);" src="{{courseCover || '/icons/svg/course.svg'}}" mode="aspectFill" />
    </view>

    <!-- 课程信息 -->
    <view class="course-info-section">
      <text class="course-title">{{courseName || '未知课程'}}</text>
      <text class="course-author">{{course.author || '未知作者'}}</text>
      <view class="chapter-title-line">
        <text class="chapter-seq">{{currentChapter.seq}}</text>
        <text class="chapter-sep">|</text>
        <text class="chapter-name">{{currentChapter.title}}</text>
      </view>
    </view>

    <!-- 进度行 -->
    <view class="progress-row">
      <text class="time-text">{{currentTimeText}}</text>
      <slider class="progress-slider" min="0" max="100" value="{{progressPercent}}"
        block-size="12" activeColor="#FF6B00" backgroundColor="rgba(255,255,255,0.3)"
        bindchange="onSliderChange" bindchanging="onSliderChanging" />
      <text class="time-text" bindtap="toggleTimeDisplay">{{remainingTimeText}}</text>
    </view>

    <!-- 播放控制按钮 -->
    <view class="play-controls">
      <view class="control-btn prev-btn" bindtap="playPrev">
        <text class="prev-icon-text">◀</text>
      </view>
      <view class="control-btn rewind-btn" bindtap="rewind15">
        <text class="rewind-text">-15</text>
      </view>
      <view class="control-btn play-pause-btn" bindtap="togglePlayPause">
        <view class="play-icon-cs" wx:if="{{!isPlaying}}"></view>
        <view class="pause-icon-cs" wx:else>
          <view class="pause-bar-cs"></view>
          <view class="pause-bar-cs"></view>
        </view>
      </view>
      <view class="control-btn forward-btn" bindtap="forward30">
        <text class="forward-text">+30</text>
      </view>
      <view class="control-btn next-btn" bindtap="playNext">
        <text class="next-icon-text">▶</text>
      </view>
    </view>

    <!-- 功能按钮行 -->
    <view class="func-row">
      <view class="func-btn mode-btn" bindtap="togglePlayMode">
        <view class="mode-icon {{playMode}}">
          <text class="mode-text" wx:if="{{playMode === 'sequence'}}">→</text>
          <text class="mode-text" wx:elif="{{playMode === 'loop'}}">↻</text>
          <text class="mode-text" wx:else>1</text>
        </view>
      </view>
      <view class="func-btn playlist-btn" bindtap="onPlaylistTap">
        <view class="playlist-icon">
          <view class="list-bar"></view>
          <view class="list-bar"></view>
          <view class="list-bar"></view>
        </view>
      </view>
      <view class="func-btn favorite-btn {{isFavorite ? 'favorited' : ''}}" bindtap="toggleFavorite">
        <text class="favorite-icon">♡</text>
      </view>
      <view class="func-btn sort-btn" bindtap="toggleSort">
        <text class="sort-text">{{playlistSortOrder === 'asc' ? '↑' : '↓'}}</text>
      </view>
      <view class="func-btn speed-btn">
        <text class="speed-text">{{playbackRate}}x</text>
      </view>
    </view>

    <!-- 倍速调整 -->
    <view class="speed-control">
      <view class="speed-track-wrap" bindtap="onSpeedTrackTap" bindtouchstart="onSpeedTouchStart" bindtouchmove="onSpeedTouchMove" bindtouchend="onSpeedTouchEnd">
        <text class="speed-mark {{playbackRate === 0.75 ? 'active' : ''}}">0.75</text>
        <text class="speed-mark {{playbackRate === 1 ? 'active' : ''}}">1</text>
        <text class="speed-mark {{playbackRate === 1.25 ? 'active' : ''}}">1.25</text>
        <text class="speed-mark {{playbackRate === 1.5 ? 'active' : ''}}">1.5</text>
        <text class="speed-mark {{playbackRate === 2 ? 'active' : ''}}">2</text>
        <view class="speed-indicator" style="left: {{speedIndicatorPos}}%;">
          <text class="speed-indicator-text">{{playbackRate}}</text>
        </view>
      </view>
    </view>

    <!-- 下一条信息 -->
    <view class="next-info">
      <text class="next-info-label">下一条：</text>
      <text class="next-info-seq" wx:if="{{nextChapterSeq}}">{{nextChapterSeq}}</text>
      <text class="next-info-sep" wx:if="{{nextChapterSeq}}">|</text>
      <text class="next-info-title">{{nextChapterTitle}}</text>
    </view>
  </view>
</page-container>