/* mini-player/index.wxss */

.mini-player {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  background: #fff;
  border-radius: 60rpx;
  z-index: 9999;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
}

.mini-player.fade-in {
  animation: fadeIn 0.3s ease forwards;
}

.mini-player.fade-out {
  animation: fadeOut 0.3s ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.chapter-cover {
  width: 70rpx;
  height: 70rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.chapter-info {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
}

.chapter-title {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chapter-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dot {
  margin: 0 8rpx;
}

.chapter-seq {
  color: #FF6B00;
}

.action-buttons {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.playlist-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.playlist-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.playlist-line {
  width: 22rpx;
  height: 5rpx;
  background: #999;
  border-radius: 1rpx;
}

.speed-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.speed-text {
  font-size: 26rpx;
  color: #FF6B00;
  font-weight: 500;
}

.play-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.play-icon {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 18rpx solid #999;
  margin-left: 5rpx;
}

.play-icon.pause {
  width: 20rpx;
  height: 22rpx;
  border: none;
  background: transparent;
  margin-left: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pause-bar {
  width: 6rpx;
  height: 22rpx;
  background: #999;
  border-radius: 2rpx;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.close-text {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.progress-bar {
  position: absolute;
  bottom: 12rpx;
  left: 40rpx;
  right: 40rpx;
  height: 4rpx;
  background: #eee;
  border-radius: 2rpx;
}

.progress-fill {
  height: 100%;
  background: #FF6B00;
  border-radius: 2rpx;
}