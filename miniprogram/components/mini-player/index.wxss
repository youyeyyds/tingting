/* mini-player/index.wxss */

.mini-player {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  background: #fff;
  border-radius: 60rpx;
  z-index: 9999;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
}

.mini-player.fade-in {
  animation: fadeIn 0.3s ease forwards;
}

.mini-player.fade-out {
  animation: fadeOut 0.3s ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

/* 左边可点击区域 */
.left-area {
  display: flex;
  align-items: center;
  flex: 1;
}

.chapter-cover {
  width: 70rpx;
  height: 70rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.chapter-info {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
}

.chapter-title {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chapter-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dot {
  margin: 0 8rpx;
}

.chapter-seq {
  color: #FF6B00;
}

.action-buttons {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.playlist-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.playlist-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.playlist-line {
  width: 22rpx;
  height: 5rpx;
  background: #999;
  border-radius: 1rpx;
}

.speed-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.speed-text {
  font-size: 26rpx;
  color: #FF6B00;
  font-weight: 500;
}

.play-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.play-icon {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 18rpx solid #999;
  margin-left: 5rpx;
}

.play-icon.pause {
  width: 20rpx;
  height: 22rpx;
  border: none;
  background: transparent;
  margin-left: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pause-bar {
  width: 6rpx;
  height: 22rpx;
  background: #999;
  border-radius: 2rpx;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.close-text {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.progress-bar {
  position: absolute;
  bottom: 12rpx;
  left: 40rpx;
  right: 40rpx;
  height: 4rpx;
  background: #eee;
  border-radius: 2rpx;
}

.progress-fill {
  height: 100%;
  background: #FF6B00;
  border-radius: 2rpx;
}

/* ========== 播放器面板样式 ========== */

.player-container {
  position: relative;
  height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 10001;
}

/* 收起按钮（向下箭头） */
.header-area {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.collapse-icon {
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg);
}

/* 封面图 */
.cover-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 0 40rpx;
}

.cover-image {
  width: 320rpx;
  height: 320rpx;
  border-radius: 160rpx;
}

.cover-image.playing {
  transition: transform 0.05s linear;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 课程信息 */
.course-info-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
}

.course-info-section .course-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.course-info-section .course-author {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 16rpx;
}

.chapter-title-line {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
}

.chapter-title-line .chapter-seq {
  font-size: 28rpx;
  color: #FF6B00;
  font-weight: 500;
  flex-shrink: 0;
}

.chapter-title-line .chapter-sep {
  font-size: 28rpx;
  color: #FF6B00;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.chapter-title-line .chapter-name {
  font-size: 28rpx;
  color: #FF6B00;
  font-weight: 500;
  word-break: break-all;
}

/* 进度行 */
.progress-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.time-text {
  font-size: 26rpx;
  color: #fff;
  width: 100rpx;
  text-align: center;
}

.progress-slider {
  flex: 1;
  margin: 0 20rpx;
}

/* 播放控制按钮 */
.play-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 55rpx;
  padding: 50rpx 0;
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.prev-btn, .next-btn {
  width: 60rpx;
  height: 60rpx;
}

.prev-icon-text, .next-icon-text {
  font-size: 32rpx;
  color: #fff;
}

.rewind-btn, .forward-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 35rpx;
  background: rgba(255, 255, 255, 0.1);
}

.rewind-text, .forward-text {
  font-size: 22rpx;
  color: #fff;
}

.play-pause-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #FF6B00;
}

.play-pause-btn .play-icon-text {
  font-size: 40rpx;
  color: #fff;
  margin-left: 6rpx;
}

.play-pause-btn .play-icon-cs {
  width: 0;
  height: 0;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #fff;
  border-radius: 4rpx;
  margin-left: 8rpx;
}

.play-pause-btn .pause-icon-cs {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.play-pause-btn .pause-bar-cs {
  width: 8rpx;
  height: 28rpx;
  background: #fff;
  border-radius: 4rpx;
}

/* 功能按钮行 */
.func-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 50rpx;
  padding: 50rpx 0;
}

.func-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
}

.mode-icon {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.playlist-icon {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.list-bar {
  width: 40rpx;
  height: 5rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 1rpx;
}

.func-btn .speed-text {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 600;
}

.sort-text {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.7);
}

.favorite-btn.favorited .favorite-icon {
  color: #FF6B00;
}

.favorite-icon {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 倍速控制 */
.speed-control {
  padding: 30rpx 0 60rpx;
}

.speed-track-wrap {
  position: relative;
  width: 100%;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.speed-track-wrap .speed-mark {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.6);
  z-index: 1;
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}

.speed-track-wrap .speed-mark.active {
  color: transparent;
}

.speed-indicator {
  position: absolute;
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(180deg, #FF6B00 0%, #FF8C42 100%);
  border-radius: 45rpx;
  top: 15rpx;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(255, 107, 0, 0.6), 0 0 40rpx rgba(255, 140, 66, 0.3);
}

.speed-indicator-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

/* 下一条信息 */
.next-info {
  padding: 20rpx 0;
  text-align: center;
  display: flex;
  justify-content: center;
}

.next-info-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
}

.next-info-seq {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
}

.next-info-sep {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin: 0 8rpx;
  flex-shrink: 0;
}

.next-info-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}