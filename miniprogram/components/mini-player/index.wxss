/* mini-player/index.wxss */

.mini-player {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  background: #fff;
  border-radius: 60rpx;
  z-index: 1000;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 28rpx;
  transform: translateY(100%);
  opacity: 0;
  transition: transform 0.3s ease, opacity 0.3s ease, bottom 0.3s ease;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
}

.mini-player.show {
  transform: translateY(0);
  opacity: 1;
}

.chapter-cover {
  width: 70rpx;
  height: 70rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.chapter-info {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
}

.chapter-title {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chapter-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dot {
  margin: 0 8rpx;
}

.chapter-seq {
  color: #FF6B00;
}

/* 播放列表按钮 */
.playlist-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.playlist-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3rpx;
}

.playlist-line {
  width: 22rpx;
  height: 3rpx;
  background: #999;
  border-radius: 1rpx;
}

/* 倍速按钮 */
.speed-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.speed-text {
  font-size: 24rpx;
  color: #FF6B00;
  font-weight: 500;
}

/* 播放按钮 */
.play-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* 播放图标 */
.play-icon {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 18rpx solid #999;
  margin-left: 6rpx;
}

/* 暂停图标容器 */
.play-icon.pause {
  width: 20rpx;
  height: 22rpx;
  border: none;
  background: transparent;
  margin-left: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 暂停竖条 */
.pause-bar {
  width: 6rpx;
  height: 22rpx;
  background: #999;
  border-radius: 2rpx;
}

/* 关闭按钮 */
.close-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.close-text {
  font-size: 36rpx;
  color: #999;
  line-height: 1;
}

/* 进度条 */
.progress-bar {
  position: absolute;
  bottom: 12rpx;
  left: 40rpx;
  right: 40rpx;
  height: 4rpx;
  background: #eee;
  border-radius: 2rpx;
}

.progress-fill {
  height: 100%;
  background: #FF6B00;
  border-radius: 2rpx;
}