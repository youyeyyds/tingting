/* mini-player/index.wxss */

.mini-player {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  background: #fff;
  border-radius: 60rpx;
  z-index: 9999;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
}

.mini-player.fade-in {
  animation: fadeIn 0.3s ease forwards;
}

.mini-player.fade-out {
  animation: fadeOut 0.3s ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

/* 左边可点击区域 */
.left-area {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.chapter-cover {
  width: 70rpx;
  height: 70rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.chapter-info {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
}

.chapter-title {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.chapter-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dot {
  margin: 0 8rpx;
}

.chapter-seq {
  color: #FF6B00;
}

.action-buttons {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.playlist-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 迷你播放器播放列表图标，gap为5rpx */
.mini-player .playlist-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
}

.mini-player .playlist-line {
  width: 22rpx;
  height: 5rpx;
  background: #999;
  border-radius: 1rpx;
}

.speed-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.speed-text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}
.speed-text.active {
  color: #FF6B00;
}

.play-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.play-icon {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 18rpx solid #999;
  margin-left: 5rpx;
}

.play-icon.pause {
  width: 20rpx;
  height: 22rpx;
  border: none;
  background: transparent;
  margin-left: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pause-bar {
  width: 6rpx;
  height: 22rpx;
  background: #999;
  border-radius: 2rpx;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.close-text {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.progress-bar {
  position: absolute;
  bottom: 12rpx;
  left: 40rpx;
  right: 40rpx;
  height: 4rpx;
  background: #ddd;
  border-radius: 2rpx;
}

.progress-fill {
  height: 100%;
  background: #FF6B00;
  border-radius: 2rpx;
}

/* Player Overlay */
.player-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10000;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* Overlay background layer */
.overlay-bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.overlay-bg-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: blur(25px);
  transform: scale(1.15);
  z-index: 1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.overlay-bg-cover.loaded {
  opacity: 1;
}

.overlay-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.35) 0%, rgba(0, 0, 0, 0.45) 50%, rgba(0, 0, 0, 0.55) 100%);
  z-index: 2;
}

/* Overlay close button */
.overlay-close-btn {
  position: absolute;
  top: 60rpx;
  left: 30rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  height: 64rpx;
  padding: 0 20rpx;
}

.overlay-close-icon {
  width: 36rpx;
  height: 36rpx;
}

/* Overlay player container */
.overlay-player-container {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
  padding-top: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 10;
}

/* Overlay cover section */
.overlay-cover-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 0 40rpx;
}

.overlay-cover-image {
  width: 320rpx;
  height: 320rpx;
  border-radius: 160rpx;
}

.overlay-cover-image.playing {
  transition: transform 0.05s linear;
}

/* Overlay course info */
.overlay-course-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
}

.overlay-course-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.overlay-chapter-line {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 8rpx;
}

.overlay-chapter-seq {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 500;
  flex-shrink: 0;
}

.overlay-chapter-sep {
  font-size: 32rpx;
  color: #FF6B00;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.overlay-chapter-name {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 500;
  word-break: break-all;
}

/* Overlay progress section */
.overlay-progress-section {
  display: flex;
  flex-direction: column;
  padding: 20rpx 30rpx;
}

.overlay-progress-slider {
  width: 100%;
  margin: 0 !important;
}

.overlay-time-row {
  display: flex;
  justify-content: space-between;
  margin: 10rpx 0 0;
}

.overlay-time-text {
  font-size: 26rpx;
  color: #fff;
}

.overlay-time-text.left {
  width: 100rpx;
}

.overlay-time-text.right {
  width: 100rpx;
  text-align: right;
}

/* Overlay play controls */
.overlay-play-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 55rpx;
  padding: 50rpx 0;
}

.overlay-control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.overlay-control-btn.prev-btn, .overlay-control-btn.next-btn {
  width: 60rpx;
  height: 60rpx;
}

.prev-icon-text, .next-icon-text {
  font-size: 32rpx;
  color: #fff;
}

.overlay-control-btn.rewind-btn, .overlay-control-btn.forward-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 35rpx;
  background: rgba(255, 255, 255, 0.1);
}

.rewind-text, .forward-text {
  font-size: 22rpx;
  color: #fff;
}

.overlay-control-btn.play-pause-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #E85D00;
  box-shadow: 0 4rpx 20rpx rgba(232, 93, 0, 0.4);
}

.play-icon-cs {
  width: 0;
  height: 0;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #fff;
  border-radius: 4rpx;
  margin-left: 8rpx;
}

.pause-icon-cs {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.pause-bar-cs {
  width: 8rpx;
  height: 28rpx;
  background: #fff;
  border-radius: 4rpx;
}

/* Overlay function row */
.overlay-func-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 50rpx;
  padding: 50rpx 0;
}

.overlay-func-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
}

.mode-icon {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: bold;
}

/* Overlay playlist icon */
.overlay-player-container .playlist-icon {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.overlay-player-container .list-bar {
  width: 40rpx;
  height: 5rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 1rpx;
}

.overlay-func-btn .speed-text {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 600;
}

.sort-text {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.6);
}

.favorite-btn.favorited .favorite-icon {
  color: #FF6B00;
}

.favorite-icon {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* Overlay speed control */
.overlay-speed-control {
  padding: 30rpx 0 60rpx;
}

.overlay-speed-track-wrap {
  position: relative;
  width: 100%;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.overlay-speed-track-wrap .speed-mark {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.6);
  z-index: 1;
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}

.overlay-speed-track-wrap .speed-mark.active {
  color: transparent;
}

.overlay-speed-indicator {
  position: absolute;
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(180deg, #FF6B00 0%, #FF8C42 100%);
  border-radius: 45rpx;
  top: 15rpx;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(255, 107, 0, 0.6), 0 0 40rpx rgba(255, 140, 66, 0.3);
}

.speed-indicator-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

/* Overlay next info */
.overlay-next-info {
  padding: 20rpx 0;
  display: flex;
  justify-content: flex-start;
  padding-left: 80rpx;
}

.next-info-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.next-info-seq {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.next-info-sep {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 8rpx;
  flex-shrink: 0;
}

.next-info-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}