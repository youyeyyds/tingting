/* custom-navbar/index.wxss */

.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: transparent;
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  width: 100%;
}

.nav-btn-group {
  display: flex;
  align-items: center;
  justify-content: space-evenly;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.nav-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
}

.nav-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}