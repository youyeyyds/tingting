/* custom-navbar/index.wxss */

.custom-navbar {
  width: 100%;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
  background: #fff;
}

.custom-navbar.transparent {
  background: transparent !important;
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
}

.nav-left-btn {
  position: absolute;
  left: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
}

.nav-login-text {
  color: #FF6B00;
  font-size: 28rpx;
  font-weight: 500;
}

.nav-title-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
}

/* overlay按钮组样式 */
.overlay-nav-btn-group {
  position: absolute;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: space-evenly;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
}

.overlay-nav-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.overlay-nav-icon {
  width: 36rpx;
  height: 36rpx;
}

.overlay-nav-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}