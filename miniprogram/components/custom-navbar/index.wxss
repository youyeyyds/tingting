/* custom-navbar/index.wxss */

.custom-navbar {
  width: 100%;
  background: #fff;
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  width: 100%;
  position: relative;
}

.nav-back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
}

.nav-title-center {
  position: absolute;
  left: 100rpx;
  right: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
}