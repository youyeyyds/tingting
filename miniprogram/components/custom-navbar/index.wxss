/* custom-navbar/index.wxss */

.custom-navbar {
  width: 100%;
  background: #fff;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
}

.nav-left-btn {
  position: absolute;
  left: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
}

.nav-login-text {
  color: #FF6B00;
  font-size: 28rpx;
  font-weight: 500;
}

.nav-title-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
}