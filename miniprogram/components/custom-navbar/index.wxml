<!--custom-navbar/index.wxml-->
<view class="custom-navbar" style="height: {{statusBarHeight + navContentHeight}}px;">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏内容区域 -->
  <view class="nav-content" style="height: {{navContentHeight}}px;">
    <!-- 返回按钮 -->
    <view class="nav-back-btn" bindtap="onBack" wx:if="{{showBack}}">
      <text class="nav-back-icon">&lt;</text>
    </view>

    <!-- 标题居中 -->
    <view class="nav-title-center" wx:if="{{title}}">
      <text class="nav-title-text">{{title}}</text>
    </view>

    <!-- 首页按钮 -->
    <view class="nav-home-btn" bindtap="onHome" wx:if="{{showHome}}">
      <text class="nav-home-icon">⌂</text>
    </view>
  </view>
</view>