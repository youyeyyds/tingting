<!--custom-navbar/index.wxml-->
<view class="custom-navbar" style="height: {{statusBarHeight + navContentHeight}}px;">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏内容区域 -->
  <view class="nav-content" style="height: {{navContentHeight}}px;">
    <!-- 左侧按钮：返回 / 登录 -->
    <view class="nav-left-btn {{showLoginBtn ? 'login-btn' : ''}}" bindtap="{{showLoginBtn ? 'onLogin' : 'onBack'}}" wx:if="{{showBack || showLoginBtn}}">
      <block wx:if="{{showLoginBtn}}">
        <text class="nav-login-text">{{loginText}}</text>
      </block>
      <block wx:else>
        <image class="nav-icon" src="/icons/svg/arrow-left-black.svg" mode="aspectFit" />
      </block>
    </view>

    <!-- 标题居中 -->
    <text class="nav-title-text" wx:if="{{title}}">{{title}}</text>
  </view>
</view>