<!--custom-navbar/index.wxml-->
<view class="custom-navbar">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏内容区域 -->
  <view class="nav-content" style="height: {{navContentHeight}}px;">
    <!-- 左侧胶囊按钮 -->
    <view class="nav-btn-group" style="width: {{menuButtonWidth}}px; height: {{menuButtonHeight}}px; margin-left: {{menuButtonLeftGap}}px;">
      <!-- 返回按钮 -->
      <view class="nav-btn" bindtap="onBack">
        <image class="nav-icon" src="/icons/svg/back.svg" mode="aspectFit" />
      </view>
      <!-- 分隔线 -->
      <view class="nav-divider" style="height: {{menuButtonHeight * 0.6}}px;"></view>
      <!-- 首页按钮 -->
      <view class="nav-btn" bindtap="onHome">
        <image class="nav-icon" src="/icons/svg/home-white.svg" mode="aspectFit" />
      </view>
    </view>
  </view>
</view>