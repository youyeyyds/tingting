<!--custom-navbar/index.wxml-->
<view class="custom-navbar {{transparent ? 'transparent' : ''}}" style="height: {{statusBarHeight + navContentHeight}}px; background: {{transparent ? 'transparent' : ''}};">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏内容区域 -->
  <view class="nav-content" style="height: {{navContentHeight}}px;">
    <!-- 左侧按钮：返回 / 登录 -->
    <view class="nav-left-btn {{showLoginBtn ? 'login-btn' : ''}}" bindtap="{{showLoginBtn ? 'onLogin' : 'onBack'}}" wx:if="{{showBack || showLoginBtn}}">
      <block wx:if="{{showLoginBtn}}">
        <text class="nav-login-text">{{loginText}}</text>
      </block>
      <block wx:else>
        <image class="nav-icon" src="{{iconColor === 'white' ? '/icons/svg/arrow-left-white.svg' : '/icons/svg/arrow-left-black.svg'}}" mode="aspectFit" />
      </block>
    </view>

    <!-- 播放器overlay专用按钮组 -->
    <view class="overlay-nav-btn-group" wx:if="{{showOverlayBtns}}" style="width: {{menuButtonWidth}}px; height: {{menuButtonHeight}}px; left: {{menuButtonLeftGap}}px;">
      <view class="overlay-nav-btn" bindtap="onOverlayClose">
        <image class="overlay-nav-icon" src="{{overlayCloseIcon}}" mode="aspectFit" />
      </view>
      <view class="overlay-nav-divider" style="height: {{menuButtonHeight * 0.6}}px;"></view>
      <view class="overlay-nav-btn" bindtap="onOverlayHome">
        <image class="overlay-nav-icon" src="{{overlayHomeIcon}}" mode="aspectFit" />
      </view>
    </view>

    <!-- 标题居中 -->
    <text class="nav-title-text {{titleColor === 'white' ? 'white-title' : ''}}" wx:if="{{title}}">{{title}}</text>
  </view>
</view>