/* play-btn/index.wxss - backup styles */

/* 播放图标 - 三角形 */
.play-icon {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 18rpx solid #999;
  margin-left: 5rpx;
}

/* 暂停图标 - 双竖线 */
.pause-icon {
  width: 20rpx;
  height: 22rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: transparent;
}

/* 暂停条 */
.pause-bar {
  width: 6rpx;
  height: 22rpx;
  background: #999;
  border-radius: 2rpx;
}