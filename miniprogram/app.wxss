/**app.wxss**/

page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333333;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 主题色 */
.text-primary {
  color: #FF6B00;
}

.bg-primary {
  background-color: #FF6B00;
}

/* 常用样式 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.align-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}