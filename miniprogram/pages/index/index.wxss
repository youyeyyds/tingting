/* index.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 固定顶部 */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

/* 状态栏占位 */
.status-bar {
  background: #fff;
}

/* 标题栏 */
.title-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  position: relative;
}

.login-btn {
  position: absolute;
  left: 30rpx;
  width: 130rpx;
}

.login-text {
  color: #FF6B00;
  font-size: 28rpx;
  font-weight: 500;
}

.title-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
}

/* 课程列表 */
.course-list {
  flex: 1;
  overflow-x: hidden;
}

.course-list-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* BANNER */
.banner {
  width: 100%;
  height: 280rpx;
  margin-bottom: 20rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.course-card {
  width: 690rpx;
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  overflow: hidden;
}

.course-card.first-card {
  margin-top: 20rpx;
}

.course-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.course-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  padding-left: 20rpx;
  justify-content: space-between;
  overflow: hidden;
}

.course-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-author {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  display: flex;
  align-items: center;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.list-bottom {
  height: 5rpx;
}

/* 空状态提示 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  margin-top: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #ddd;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}

/* 骨架屏 */
.skeleton-card {
  width: 690rpx;
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.skeleton-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.skeleton-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.skeleton-title {
  height: 32rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

.skeleton-author {
  height: 26rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

.skeleton-meta {
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

/* 退出登录确认弹窗 */
.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10001;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.confirm-content {
  position: relative;
  width: 480rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 56rpx 32rpx 48rpx;
  text-align: center;
}

.confirm-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
}

.confirm-buttons {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 56rpx;
}

.confirm-btn {
  padding: 20rpx 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.confirm-btn.cancel {
  background: #f5f5f5;
  color: #FF6B00;
}

.confirm-btn.confirm {
  background: #FF6B00;
  color: #fff;
}

/* 武功详情半屏弹窗 */
.martial-art-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
}

.martial-art-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.martial-art-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.martial-art-content.show {
  animation: slideUp 0.3s ease forwards;
}

.martial-art-content.hide {
  animation: slideDown 0.3s ease forwards;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes slideDown {
  from {
    transform: translateY(0);
  }
  to {
    transform: translateY(100%);
  }
}

.martial-art-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  padding-left: 48rpx;
  padding-right: 48rpx;
  border-bottom: 1rpx solid #eee;
}

.martial-art-collapse {
  width: 120rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.collapse-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  transform: rotate(90deg);
  display: block;
}

.martial-art-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
}

.martial-art-novel {
  font-size: 24rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.martial-art-body {
  padding: 32rpx 48rpx;
  flex: 1;
  overflow-y: auto;
}

.martial-art-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: left;
  white-space: pre-wrap;
  word-wrap: break-word;
  display: block;
  margin-bottom: 20rpx;
}

.martial-art-signature {
  display: block;
  margin-top: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.martial-art-footer {
  display: none;
}