<!--mine/index.wxml-->
<view class="page-container {{pageAnimating ? 'page-exit' : ''}}">
  <!-- 导航栏 -->
  <custom-navbar showBack="{{true}}" title="我的" />

  <!-- 内容区域，使用原生页面滚动 -->
  <view class="content" style="margin-top: {{headerHeight}}px; height: {{scrollHeight}}px;">
    <!-- 头条轮播 -->
    <swiper class="banner" indicator-dots="{{headlines.length > 1}}" autoplay="{{true}}" interval="{{bannerSpeed}}" circular="{{true}}" wx:if="{{headlines.length > 0}}">
      <swiper-item wx:for="{{headlines}}" wx:key="_id">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
    <!-- 横幅占位 -->
    <view class="banner-placeholder" wx:else></view>

    <!-- 用户信息 -->
    <view class="user-card">
      <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" />
      <text class="nickname">{{userInfo.nickName || '用户'}}</text>
      <text class="phone">{{maskedPhone}}</text>
    </view>

    <!-- 学习报告标题卡 -->
    <view class="stats-card stats-card-header">
      <text class="stats-title">学习报告</text>
    </view>

    <!-- 学习报告 - 课程 -->
    <view class="stats-card stats-card-row">
      <text class="stats-label">课程</text>
      <view class="stats-value">
        <text>学了</text>
        <text class="stats-number">{{stats.learnedCourses || 0}}</text>
        <text>门 / 毕业</text>
        <text class="stats-number">{{stats.graduatedCourses || 0}}</text>
        <text>门</text>
      </view>
    </view>

    <!-- 学习报告 - 收藏 -->
    <view class="stats-card stats-card-row">
      <text class="stats-label">收藏</text>
      <view class="stats-value">
        <text>共</text>
        <text class="stats-number">{{stats.favoriteCount || 0}}</text>
        <text>章</text>
      </view>
    </view>

    <!-- 学习报告 - 播放次数 -->
    <view class="stats-card stats-card-row">
      <text class="stats-label">播放次数</text>
      <view class="stats-value">
        <text>共</text>
        <text class="stats-number">{{stats.totalPlayCount || 0}}</text>
        <text>次</text>
      </view>
    </view>

    <!-- 学习报告 - 学习时长 -->
    <view class="stats-card stats-card-row">
      <text class="stats-label">学习时长</text>
      <view class="stats-value">
        <text class="stats-number" wx:if="{{studyTime.days > 0}}">{{studyTime.days}}</text>
        <text wx:if="{{studyTime.days > 0}}">天</text>
        <text class="stats-number" wx:if="{{studyTime.hours > 0}}">{{studyTime.hours}}</text>
        <text wx:if="{{studyTime.hours > 0}}">时</text>
        <text class="stats-number">{{studyTime.mins}}</text>
        <text>分</text>
      </view>
    </view>

    <!-- 学习报告 - 加入听听 -->
    <view class="stats-card stats-card-row stats-card-last">
      <text class="stats-label">加入听听</text>
      <view class="stats-value">
        <text class="stats-number" wx:if="{{joinedTime.days > 0}}">{{joinedTime.days}}</text>
        <text wx:if="{{joinedTime.days > 0}}">天</text>
        <text class="stats-number" wx:if="{{joinedTime.hours > 0}}">{{joinedTime.hours}}</text>
        <text wx:if="{{joinedTime.hours > 0}}">时</text>
        <text class="stats-number">{{joinedTime.mins}}</text>
        <text>分</text>
      </view>
    </view>

    <!-- 设置卡片 -->
    <view class="settings-card settings-card-group-first" bindtap="onRefreshTap">
      <text class="settings-label">刷新图片</text>
      <view class="settings-arrow"></view>
    </view>

    <view class="settings-card settings-card-group-middle" bindtap="handleChangeAvatar">
      <text class="settings-label">更换头像</text>
      <view class="settings-arrow"></view>
    </view>

    <view class="settings-card settings-card-group-middle" bindtap="handleChangeNickname">
      <text class="settings-label">更换昵称</text>
      <view class="settings-arrow"></view>
    </view>

    <view class="settings-card settings-card-group-last" bindtap="handleChangePassword">
      <text class="settings-label">修改密码</text>
      <view class="settings-arrow"></view>
    </view>

    <!-- 卡片组：卡牌和丽音 -->
    <view class="settings-card settings-card-group-first" bindtap="onCardTap">
      <text class="settings-label">卡牌</text>
      <view class="settings-arrow"></view>
    </view>

    <view class="settings-card settings-card-group-last" bindtap="onCardTap">
      <text class="settings-label">丽音</text>
      <view class="settings-arrow"></view>
    </view>

    <!-- 版本介绍（单卡片） -->
    <view class="settings-card settings-card-single" bindtap="handleVersionInfo">
      <text class="settings-label">版本介绍</text>
      <view class="settings-arrow"></view>
    </view>

    <!-- 退出登录按钮 -->
    <view class="settings-card settings-card-single logout-card" bindtap="onLogoutTap">
      <text class="logout-text">退出登录</text>
    </view>

    <!-- 刷新图片确认弹窗 -->
    <view wx:if="{{refreshConfirmVisible}}" class="confirm-modal">
      <view class="confirm-mask" catchtap="onRefreshCancel"></view>
      <view class="confirm-content">
        <text class="confirm-text">确定要刷新图片吗？</text>
        <view class="confirm-buttons">
          <view class="confirm-btn cancel" catchtap="onRefreshCancel">取消</view>
          <view class="confirm-btn confirm" catchtap="onRefreshConfirm">确定</view>
        </view>
      </view>
    </view>

    <!-- 退出登录确认弹窗 -->
    <view wx:if="{{logoutConfirmVisible}}" class="confirm-modal">
      <view class="confirm-mask" catchtap="onLogoutCancel"></view>
      <view class="confirm-content">
        <text class="confirm-text">确定要退出登录吗？</text>
        <view class="confirm-buttons">
          <view class="confirm-btn cancel" catchtap="onLogoutCancel">取消</view>
          <view class="confirm-btn confirm" catchtap="onLogoutConfirm">确定</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 0 ? '/icons/svg/home-active.svg' : '/icons/svg/home.svg'}}" mode="aspectFit" />
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 1 ? '/icons/svg/favorite-active.svg' : '/icons/svg/favorite.svg'}}" mode="aspectFit" />
      <text class="tab-text">收藏</text>
    </view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" data-index="2" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 2 ? '/icons/svg/mine-active.svg' : '/icons/svg/mine.svg'}}" mode="aspectFit" />
      <text class="tab-text">我的</text>
    </view>
  </view>

  <!-- 迷你播放器 -->
  <mini-player id="miniPlayer" />
</view>