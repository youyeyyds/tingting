<!--mine/index.wxml-->
<view class="page-container">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="header" style="height: {{navBarHeight}}px;">
    <text class="header-title">我的</text>
  </view>

  <scroll-view class="content" scroll-y="true" enhanced="true"
    refresher-enabled="{{true}}" refresher-triggered="{{refresherTriggered}}" refresher-threshold="{{80}}" bindrefresherrefresh="onRefresh">
    <!-- 头条轮播 -->
    <swiper class="banner" indicator-dots="{{headlines.length > 1}}" autoplay="{{true}}" interval="{{3000}}" circular="{{true}}" wx:if="{{headlines.length > 0}}">
      <swiper-item wx:for="{{headlines}}" wx:key="_id">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
    <!-- 横幅占位 -->
    <view class="banner-placeholder" wx:else></view>

    <!-- 未登录状态 -->
    <view class="user-card" wx:if="{{!isLoggedIn}}">
      <image class="avatar" src="https://picsum.photos/seed/avatar/200/200" mode="aspectFill" />
      <text class="nickname">未登录</text>
      <button class="login-btn" bindtap="handleLogin">登录</button>
    </view>

    <!-- 已登录状态 -->
    <view class="user-card" wx:if="{{isLoggedIn}}">
      <image class="avatar" src="{{userInfo.avatarUrl || 'https://picsum.photos/seed/avatar/200/200'}}" mode="aspectFill" />
      <text class="nickname">{{userInfo.nickName || '用户'}}</text>
      <text class="phone">{{userInfo.phone || ''}}</text>
    </view>

    <!-- 学习报告（已登录时显示） -->
    <view class="stats-card" wx:if="{{isLoggedIn}}">
      <view class="stats-row stats-header">
        <text class="stats-title">学习报告</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-row">
        <text class="stats-label">课程</text>
        <text class="stats-value">学了 {{stats.learnedCourses || 0}} 门 / 毕业 {{stats.graduatedCourses || 0}} 门</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-row">
        <text class="stats-label">收藏</text>
        <text class="stats-value">共 {{stats.favoriteCount || 0}} 章</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-row">
        <text class="stats-label">播放次数</text>
        <text class="stats-value">共 {{stats.totalPlayCount || 0}} 次</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-row">
        <text class="stats-label">学习时长</text>
        <text class="stats-value">{{stats.totalStudyMinutes || 0}} 分</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-row">
        <text class="stats-label">加入听听</text>
        <text class="stats-value">{{stats.joinedMinutes || 0}} 分</text>
      </view>
    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-section" wx:if="{{isLoggedIn}}">
      <button class="logout-btn" bindtap="handleLogout">退出登录</button>
    </view>
  </scroll-view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 0 ? '/icons/svg/home-active.svg' : '/icons/svg/home.svg'}}" mode="aspectFit" />
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 1 ? '/icons/svg/favorite-active.svg' : '/icons/svg/favorite.svg'}}" mode="aspectFit" />
      <text class="tab-text">收藏</text>
    </view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" data-index="2" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 2 ? '/icons/svg/mine-active.svg' : '/icons/svg/mine.svg'}}" mode="aspectFit" />
      <text class="tab-text">我的</text>
    </view>
  </view>

  <!-- 迷你播放器 -->
  <mini-player id="miniPlayer" />
</view>