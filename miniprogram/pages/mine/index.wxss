/* mine/index.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 状态栏占位 */
.status-bar {
  background: #fff;
}

/* 标题栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.header-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.content {
  flex: 1;
  padding: 30rpx;
  padding-bottom: 100rpx;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: #fff;
  border-radius: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #eee;
}

.nickname {
  font-size: 32rpx;
  color: #333;
  margin-top: 20rpx;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}