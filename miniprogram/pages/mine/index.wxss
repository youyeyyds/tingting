/* mine/index.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 页面退出动画 */
.page-exit {
  animation: pageExit 0.2s ease forwards;
}

@keyframes pageExit {
  from {
    opacity: 1;
    transform: translateX(0);
  }
  to {
    opacity: 0;
    transform: translateX(-30rpx);
  }
}

/* 内容区域 */
.content {
  flex: 1;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom, 0));
}

/* 头条轮播 */
.banner {
  width: 100%;
  height: 280rpx;
}

.banner-placeholder {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx 0;
  margin: 30rpx 30rpx 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #ddd;
}

.nickname {
  font-size: 32rpx;
  color: #333;
  margin-top: 20rpx;
}

.phone {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #ddd;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}

/* 学习报告卡片组 */
.stats-card {
  margin-left: 30rpx;
  margin-right: 30rpx;
  background: #fff;
}

/* 标题卡：第一个，上方圆角 */
.stats-card-header {
  border-radius: 16rpx 16rpx 0 0;
  padding: 28rpx 36rpx;
  margin-top: 40rpx;
  position: relative;
}

/* 标题卡底部加分隔线 */
.stats-card-header::after {
  content: '';
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  bottom: 0;
  height: 1rpx;
  background: #ddd;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 数据行卡：无圆角，用分隔线隔开 */
.stats-card-row {
  padding: 28rpx 36rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
}

/* 分隔线：只在内容区有，左右各36rpx */
.stats-card-row::after {
  content: '';
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  bottom: 0;
  height: 1rpx;
  background: #ddd;
}

/* 最后一个卡片不需要分隔线 */
.stats-card-last::after {
  display: none;
}

/* 最后一个卡片，下方圆角 */
.stats-card-last {
  border-radius: 0 0 16rpx 16rpx;
  position: relative;
}

/* 最后一个卡片底部加分隔线 */
.stats-card-last::after {
  content: '';
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  bottom: 0;
  height: 1rpx;
  background: #ddd;
}

/* 整个学习报告卡片组和下方的间距 */
.stats-card-last {
  margin-bottom: 40rpx;
}

.stats-label {
  font-size: 28rpx;
  color: #333;
}

.stats-value {
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.stats-number {
  color: #FF6B00;
  font-weight: 600;
  margin-left: 8rpx;
  margin-right: 8rpx;
}

/* 设置卡片组 */
.settings-card {
  margin-left: 30rpx;
  margin-right: 30rpx;
  padding: 32rpx 36rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  box-sizing: border-box;
}

/* 第一个：上方圆角 */
.settings-card-group-first {
  border-radius: 16rpx 16rpx 0 0;
  margin-top: 40rpx;
}

.settings-card-group-first::after {
  content: '';
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  bottom: 0;
  height: 1rpx;
  background: #ddd;
}

/* 中间的卡片：分隔线 */
.settings-card-group-middle::after {
  content: '';
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  bottom: 0;
  height: 1rpx;
  background: #ddd;
}

/* 最后一个：下方圆角 */
.settings-card-group-last {
  border-radius: 0 0 16rpx 16rpx;
  margin-bottom: 40rpx;
}

.settings-card-group-last::after {
  display: none;
}

/* 单卡片：上下圆角 */
.settings-card-single {
  border-radius: 16rpx;
  margin-top: 40rpx;
  margin-bottom: 40rpx;
}

/* 单卡片底部圆角和上方圆角 */
.settings-card-single::after {
  display: none;
}

.settings-label {
  font-size: 28rpx;
  color: #333;
}

.settings-arrow {
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #ccc;
  border-bottom: 3rpx solid #ccc;
  transform: rotate(-135deg);
}

/* 退出登录卡片 */
.logout-card {
  margin: 20rpx 30rpx 40rpx;
  border-radius: 16rpx;
  justify-content: center;
}

.logout-text {
  font-size: 28rpx;
  color: #FF6B00;
  font-weight: 600;
}

/* 确认弹窗 */
.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10001;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.confirm-content {
  position: relative;
  width: 480rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 56rpx 32rpx 48rpx;
  text-align: center;
}

.confirm-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
}

.confirm-buttons {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 56rpx;
}

.confirm-btn {
  padding: 20rpx 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.confirm-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn.confirm {
  background: #FF6B00;
  color: #fff;
}