/* mine/index.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 页面退出动画 */
.page-exit {
  animation: pageExit 0.2s ease forwards;
}

@keyframes pageExit {
  from {
    opacity: 1;
    transform: translateX(0);
  }
  to {
    opacity: 0;
    transform: translateX(-30rpx);
  }
}

/* 内容区域 */
.content {
  flex: 1;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom, 0));
}

/* 头条轮播 */
.banner {
  width: 100%;
  height: 280rpx;
}

.banner-placeholder {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 40rpx;
  margin: 0 30rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  position: relative;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #eee;
}

.nickname {
  font-size: 32rpx;
  color: #333;
  margin-top: 20rpx;
}

.phone {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}

/* 学习报告卡片 */
.stats-card {
  margin: 20rpx 30rpx 0;
  background: #fff;
  border-radius: 16rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 36rpx;
}

.stats-label {
  font-size: 28rpx;
  color: #333;
}

.stats-value {
  font-size: 28rpx;
  color: #333;
}

.stats-number {
  color: #FF6B00;
  font-weight: 600;
  margin-left: 8rpx;
  margin-right: 8rpx;
}

/* 分隔线 */
.section-divider {
  height: 20rpx;
}

/* 设置卡片 */
.settings-card {
  margin: 0 30rpx;
  padding: 32rpx 36rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.settings-card + .settings-card {
  margin-top: 2rpx;
  border-radius: 0;
}

.settings-card:first-of-type {
  border-radius: 16rpx 16rpx 0 0;
}

.settings-card:last-of-type {
  border-radius: 0 0 16rpx 16rpx;
}

.settings-label {
  font-size: 28rpx;
  color: #333;
}

.settings-arrow {
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #ccc;
  border-bottom: 3rpx solid #ccc;
  transform: rotate(-135deg);
}

/* 退出登录 */
.logout-section {
  margin: 20rpx 30rpx 0;
}

.logout-btn {
  width: 100%;
  padding: 24rpx 0;
  background: #fff;
  color: #FF6B00;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}

.logout-btn::after {
  border: none;
}