/* mine/index.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 状态栏占位 */
.status-bar {
  background: #fff;
}

/* 标题栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.header-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.content {
  flex: 1;
  padding-bottom: 100rpx;
}

/* 头条轮播 */
.banner {
  width: 100%;
  height: 280rpx;
}

.banner-placeholder {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  margin: 20rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #eee;
}

.nickname {
  font-size: 32rpx;
  color: #333;
  margin-top: 20rpx;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}

/* 登录按钮 */
.login-btn {
  margin-top: 20rpx;
  padding: 16rpx 60rpx;
  background: #FF6B00;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

/* 手机号 */
.phone {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 学习报告卡片 */
.stats-card {
  margin: 30rpx 30rpx 0;
  padding: 0;
  background: #fff;
  border-radius: 16rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
}

.stats-header {
  justify-content: flex-start;
}

.stats-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.stats-divider {
  height: 1rpx;
  background: #eee;
  margin: 0 30rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #666;
}

.stats-value {
  font-size: 26rpx;
  color: #333;
}

.stats-number {
  color: #FF6B00;
  font-weight: 600;
}

/* 退出登录 */
.logout-section {
  margin: 30rpx 30rpx 0;
}

.logout-btn {
  width: 100%;
  padding: 24rpx 0;
  background: #FF6B00;
  color: #fff;
  font-size: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.logout-btn::after {
  border: none;
}