<!--chapter.wxml-->
<view class="page-container">
  <!-- 课程信息区 -->
  <view class="course-info-section">
    <image class="course-cover" src="{{course.cover}}" mode="aspectFill" />
    <view class="course-details">
      <view class="course-title">{{course.title}}</view>
      <view class="course-author">{{course.author}}</view>
      <view class="course-meta">{{course.categoryName}} · {{course.chapterCount}}章 · {{course.progressText}}</view>
      <!-- 播放按钮组：两个重叠的按钮 -->
      <view class="play-btn-group">
        <!-- play-btn1 (bottom): 只显示三角形，创建完整播放列表（不受筛选影响） -->
        <view class="play-btn play-btn-1 {{!hasPlaylist ? 'active' : ''}}" bindtap="handleCreatePlaylist">
          <view class="play-icon"></view>
          <text class="play-btn-text">继续播放</text>
        </view>
        <!-- play-btn2 (top): 播放/暂停切换，与mini-player风格一致 -->
        <view class="play-btn play-btn-2 {{hasPlaylist ? 'active' : ''}}" bindtap="handleTogglePlay">
          <view class="play-icon {{isPlaying ? 'pause' : ''}}">
            <view class="pause-bar" wx:if="{{isPlaying}}"></view>
            <view class="pause-bar" wx:if="{{isPlaying}}"></view>
          </view>
          <text class="play-btn-text">{{isPlaying ? '暂停播放' : '继续播放'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 筛选和排序 -->
  <view class="filter-bar">
    <view class="filter-left">
      <text class="filter-label">只看未学完</text>
      <switch class="filter-switch" checked="{{showUnfinishedOnly}}" color="#FF6B00" bindchange="onFilterChange" />
    </view>
    <view class="filter-right">
      <text class="sort-arrow">{{sortOrder === 'asc' ? '↑' : '↓'}}</text>
      <text class="sort-btn" bindtap="onSortChange">{{sortOrder === 'asc' ? '正序' : '倒序'}}</text>
    </view>
  </view>

  <!-- 章节列表 -->
  <view class="chapter-list">
    <view class="chapter-card" wx:for="{{filteredChapters}}" wx:key="_id" data-id="{{item._id}}" bindtap="onChapterTap">
      <view class="chapter-info">
        <view class="chapter-title-line {{item.isPlaying ? 'playing' : ''}} {{item.progress === 100 && !item.isPlaying ? 'completed' : ''}}">
          <text class="chapter-seq" wx:if="{{item.seq !== 0}}">{{item.seq}}</text>
          <text class="chapter-sep" wx:if="{{item.seq !== 0}}">|</text>
          <text class="chapter-name">{{item.title}}</text>
        </view>
        <view class="chapter-meta-line">
          <block wx:if="{{item.progress > 0}}">
            <text class="chapter-progress">{{item.progressText}}</text>
            <text class="chapter-sep-meta">|</text>
          </block>
          <text class="chapter-duration">{{item.durationText}}</text>
        </view>
      </view>
      <view class="chapter-actions">
        <block wx:if="{{item.isPlaying}}">
          <view class="audio-icon playing" data-id="{{item._id}}" catchtap="onPlayTap">
            <view class="audio-bar audio-bar-1"></view>
            <view class="audio-bar audio-bar-2"></view>
            <view class="audio-bar audio-bar-3"></view>
          </view>
        </block>
        <block wx:else>
          <image class="action-icon" src="/icons/svg/play.svg" mode="aspectFit" data-id="{{item._id}}" catchtap="onPlayTap" />
        </block>
        <image class="action-icon" src="{{item.isFavorite ? '/icons/svg/favorite-active.svg' : '/icons/svg/favorite.svg'}}" mode="aspectFit" data-id="{{item._id}}" catchtap="onFavoriteTap" />
      </view>
      <view class="chapter-divider" wx:if="{{index < filteredChapters.length}}"></view>
    </view>

    <!-- 空状态 -->
    <view class="empty-tip" wx:if="{{!loading && filteredChapters.length === 0}}">
      <text class="empty-text">{{showUnfinishedOnly ? '所有章节已学完' : '暂无章节数据'}}</text>
    </view>

    <!-- 底部文案 -->
    <view class="list-footer" wx:if="{{filteredChapters.length > 0}}">
      <text class="footer-text">— 随时随地，学习成长 —</text>
    </view>
  </view>
</view>

<!-- 迷你播放器 -->
<mini-player id="miniPlayer" initialChapters="{{chapters}}" initialCourse="{{course}}" />