/* chapter.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 固定顶部 */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

.status-bar {
  background: #fff;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding-left: 30rpx;
  background: #fff;
}

.back-btn {
  display: flex;
  align-items: center;
}

.back-arrow {
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #333;
  border-bottom: 3rpx solid #333;
  transform: rotate(45deg);
  margin-right: 8rpx;
}

.back-text {
  font-size: 30rpx;
  color: #333;
}

/* 内容区域 */
.content-scroll {
  flex: 1;
}

.content-inner {
  padding-bottom: 0;
}

/* 课程信息区 */
.course-info-section {
  display: flex;
  padding: 40rpx 30rpx;
  background: transparent;
}

.course-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.course-details {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  padding-left: 20rpx;
  position: relative;
}

.course-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-author {
  font-size: 26rpx;
  color: #666;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.play-btn {
  position: absolute;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #FF6B00;
  border-radius: 12rpx;
}

.play-triangle {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid #fff;
}

.play-text {
  font-size: 28rpx;
  color: #fff;
  margin-left: 10rpx;
}

/* 筛选和排序 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 50rpx;
}

.filter-left {
  display: flex;
  align-items: center;
}

.filter-label {
  font-size: 26rpx;
  color: #333;
  margin-right: 10rpx;
}

.filter-switch {
  transform: scale(0.7);
}

.filter-right {
  display: flex;
  align-items: center;
}

.sort-arrow {
  font-size: 26rpx;
  color: #FF6B00;
  margin-right: 4rpx;
}

.sort-btn {
  font-size: 26rpx;
  color: #FF6B00;
}

/* 章节列表 */
.chapter-list {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin: 0 30rpx;
}

.chapter-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  position: relative;
}

.chapter-divider {
  position: absolute;
  bottom: 0;
  left: 24rpx;
  right: 24rpx;
  height: 1rpx;
  background: #eee;
}

.chapter-info {
  flex: 1;
  min-width: 0;
}

.chapter-title-line {
  display: flex;
  align-items: flex-start;
}

.chapter-seq {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex-shrink: 0;
}

.chapter-sep {
  font-size: 28rpx;
  color: #333;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.chapter-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
  flex: 1;
}

.chapter-title-line.completed .chapter-seq,
.chapter-title-line.completed .chapter-sep,
.chapter-title-line.completed .chapter-name {
  color: #999;
}

/* 播放时标题变橙色 */
.chapter-title-line.playing .chapter-seq,
.chapter-title-line.playing .chapter-sep,
.chapter-title-line.playing .chapter-name {
  color: #FF6B00;
}

.chapter-meta-line {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.chapter-progress {
  font-size: 24rpx;
  color: #999;
}

.chapter-sep-meta {
  font-size: 24rpx;
  color: #ccc;
  margin: 0 8rpx;
}

.chapter-duration {
  font-size: 24rpx;
  color: #999;
}

.chapter-actions {
  position: absolute;
  right: 24rpx;
  bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 音频跳动动画图标 */
.audio-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  width: 40rpx;
  height: 40rpx;
}

.audio-bar {
  width: 4rpx;
  height: 16rpx;
  background: #999;
  border-radius: 2rpx;
}

.audio-bar-1 {
  height: 12rpx;
}

.audio-bar-2 {
  height: 20rpx;
}

.audio-bar-3 {
  height: 16rpx;
}

/* 播动动画 */
.audio-icon.playing .audio-bar {
  background: #FF6B00;
  animation: audioWave 0.5s ease-in-out infinite alternate;
}

.audio-icon.playing .audio-bar-1 {
  animation-delay: 0s;
}

.audio-icon.playing .audio-bar-2 {
  animation-delay: 0.2s;
}

.audio-icon.playing .audio-bar-3 {
  animation-delay: 0.4s;
}

@keyframes audioWave {
  from {
    height: 8rpx;
  }
  to {
    height: 24rpx;
  }
}

/* 空状态提示 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}