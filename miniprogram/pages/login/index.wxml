<!--login/index.wxml-->
<view class="page-container">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 标题栏 -->
  <view class="header" style="height: {{navBarHeight}}px;">
    <view class="back-btn" bindtap="handleBack">
      <text class="back-arrow">←</text>
      <text class="back-text">返回</text>
    </view>
    <text class="header-title">登录</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" placeholder="请输入手机号" maxlength="11" bindinput="onPhoneInput" value="{{phone}}" />
    </view>

    <view class="form-item">
      <text class="form-label">密码</text>
      <input class="form-input" type="password" placeholder="请输入密码" bindinput="onPasswordInput" value="{{password}}" />
    </view>

    <view class="login-btn {{loading ? 'disabled' : ''}}" bindtap="handleLogin">
      <text class="login-text">{{loading ? '登录中...' : '登录'}}</text>
    </view>

    <view class="register-tip">
      <text class="tip-text">没有账号？请联系管理员注册</text>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 0 ? '/icons/svg/home-active.svg' : '/icons/svg/home.svg'}}" mode="aspectFit" />
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 1 ? '/icons/svg/favorite-active.svg' : '/icons/svg/favorite.svg'}}" mode="aspectFit" />
      <text class="tab-text">收藏</text>
    </view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" data-index="2" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 2 ? '/icons/svg/mine-active.svg' : '/icons/svg/mine.svg'}}" mode="aspectFit" />
      <text class="tab-text">我的</text>
    </view>
  </view>

  <!-- 迷你播放器 -->
  <mini-player id="miniPlayer" />
</view>