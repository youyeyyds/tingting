/* login/index.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f8f8f8 0%, #fff 100%);
  box-sizing: border-box;
  height: 100vh;
}

.scroll-content {
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

/* 内容包裹层 */
.content-inner {
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
  flex: 1;
}

/* 横幅（全宽） */
.banner {
  width: 100%;
  height: 280rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  margin-bottom: 60rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 8rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

/* 登录表单 */
.login-form {
  width: 100%;
  padding: 0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-input {
  width: 100%;
  height: 100rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  color: #333;
  border: 2rpx solid #eee;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #FF6B00;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: #FF6B00;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.login-btn.disabled {
  background: #ccc;
}

.login-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 8rpx;
}

/* 版权内容 */
.copyright-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 50rpx;
}

.copyright-line {
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.6;
}

.copyright-line-1 {
  font-size: 24rpx;
  color: #999;
}

.copyright-line-2 {
  margin-top: 4rpx;
}

.copyright-line-3 {
  margin-top: 16rpx;
}

/* 备案号（在内容底部） */
.icp-footer {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
  padding-bottom: calc(0rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.icp-text {
  font-size: 22rpx;
  color: #bbb;
}