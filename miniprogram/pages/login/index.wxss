/* login/index.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f6f6;
}

.status-bar {
  background: #fff;
}

.header {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  display: flex;
  align-items: center;
}

.back-arrow {
  font-size: 36rpx;
  color: #333;
}

.back-text {
  font-size: 28rpx;
  color: #333;
  margin-left: 10rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 头条轮播 */
.banner {
  width: 100%;
  height: 280rpx;
  margin-bottom: 20rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.login-form {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 90rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  color: #333;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  background: #FF6B00;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.login-btn.disabled {
  background: #ccc;
}

.login-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.register-tip {
  margin-top: 40rpx;
  text-align: center;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
}

/* 底部导航栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 10rpx 0;
  border-top: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}