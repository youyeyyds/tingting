/* login/index.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f8f8 0%, #fff 100%);
  box-sizing: border-box;
}

/* 顶部空白 */
.top-space {
  width: 100%;
}

/* 横幅 */
.banner {
  width: 100%;
  height: 240rpx;
  margin-bottom: 24rpx;
}

.banner-placeholder {
  width: 100%;
  height: 240rpx;
  margin-bottom: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 8rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

/* 登录表单 */
.login-form {
  width: 100%;
  padding: 0 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-input {
  width: 100%;
  height: 100rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  color: #333;
  border: 2rpx solid #eee;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #FF6B00;
}

/* 密码输入框 */
.password-item {
  display: flex;
  align-items: center;
  position: relative;
}

.password-input {
  flex: 1;
  padding-right: 80rpx;
}

.password-toggle {
  position: absolute;
  right: 30rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: #FF6B00;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.login-btn.disabled {
  background: #ccc;
}

.login-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 8rpx;
}

/* 底部版权 */
.footer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: auto;
  padding: 0 40rpx;
  padding-bottom: 40rpx;
}

.copyright-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.copyright-icon {
  width: 28rpx;
  height: 28rpx;
}

.copyright-text {
  font-size: 24rpx;
  color: #999;
}

.powered-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 12rpx;
}

.terminal-icon {
  width: 28rpx;
  height: 28rpx;
}

.powered-text {
  font-size: 22rpx;
  color: #bbb;
}