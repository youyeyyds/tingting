/* login/index.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f8f8 0%, #fff 100%);
  box-sizing: border-box;
}

/* 页面退出动画 */
.page-exit {
  animation: pageExit 0.2s ease forwards;
}

@keyframes pageExit {
  from {
    opacity: 1;
    transform: translateX(0);
  }
  to {
    opacity: 0;
    transform: translateX(-30rpx);
  }
}

/* 固定顶部导航 */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

.status-bar {
  background: #fff;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding-left: 30rpx;
  background: #fff;
}

.back-btn {
  display: flex;
  align-items: center;
}

.back-arrow {
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #333;
  border-bottom: 3rpx solid #333;
  transform: rotate(45deg);
  margin-right: 8rpx;
}

.back-text {
  font-size: 30rpx;
  color: #333;
}

/* 内容区域 */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
}

/* 横幅 */
.banner {
  width: calc(100% + 80rpx);
  height: 280rpx;
  margin-left: -40rpx;
  margin-bottom: 24rpx;
}

.banner-placeholder {
  width: calc(100% + 80rpx);
  height: 280rpx;
  margin-left: -40rpx;
  margin-bottom: 24rpx;
  background: #f5f5f5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 8rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

/* 登录表单 */
.login-form {
  width: 100%;
  padding: 0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-input {
  width: 100%;
  height: 100rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  color: #333;
  border: 2rpx solid #eee;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #FF6B00;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: #FF6B00;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.login-btn.disabled {
  background: #ccc;
}

.login-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 8rpx;
}

/* 版权内容 */
.copyright-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 50rpx;
}

.copyright-text {
  font-size: 24rpx;
  color: #999;
}

.powered-text {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 10rpx;
}

/* 备案号在底部 */
.icp-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: auto;
  padding-bottom: 40rpx;
}

.icp-text {
  font-size: 22rpx;
  color: #bbb;
}