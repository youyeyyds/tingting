/* player/index.wxss */

/* 背景图层容器 */
.bg-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  /* 默认渐变背景（无封面时显示） */
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
}

/* 背景图（先显示封面，再加载竖屏图） */
.bg-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: blur(25px);
  transform: scale(1.15);
  z-index: 1;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.bg-cover.loaded {
  opacity: 1;
}

/* 竖屏背景图（覆盖在封面之上） */
.bg-cover-portrait {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: blur(25px);
  transform: scale(1.15);
  z-index: 2;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.bg-cover-portrait.loaded {
  opacity: 1;
}

/* 轻量遮罩，保持原图色彩可见 */
.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.35) 0%, rgba(0, 0, 0, 0.45) 50%, rgba(0, 0, 0, 0.55) 100%);
  z-index: 3;
}

.player-container {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
  padding-top: 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 10;
}

/* 封面图 */
.cover-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 0 40rpx;
  margin-top: 80rpx;
}

.cover-image {
  width: 320rpx;
  height: 320rpx;
  border-radius: 160rpx;
}

.cover-image.playing {
  transition: transform 0.05s linear;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 课程信息 */
.course-info-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
}

.course-info-section .course-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.course-info-section .course-author {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 16rpx;
}

.chapter-title-line {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 8rpx;
}

.chapter-title-line .chapter-seq {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 500;
  flex-shrink: 0;
}

.chapter-title-line .chapter-sep {
  font-size: 32rpx;
  color: #FF6B00;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.chapter-title-line .chapter-name {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 500;
  word-break: break-all;
}

/* 进度区块 */
.progress-section {
  display: flex;
  flex-direction: column;
  padding: 20rpx 30rpx;
}

.progress-slider {
  width: 100%;
  margin: 0 !important;
}

.time-row {
  display: flex;
  justify-content: space-between;
  margin: 10rpx 0 0;
}

.time-text {
  font-size: 26rpx;
  color: #fff;
}

.time-text.left {
  width: 100rpx;
}

.time-text.right {
  width: 100rpx;
  text-align: right;
}

/* 播放控制按钮 */
.play-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 55rpx;
  padding: 50rpx 0;
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.prev-btn, .next-btn {
  width: 60rpx;
  height: 60rpx;
}

.prev-icon-text, .next-icon-text {
  font-size: 32rpx;
  color: #fff;
}

.rewind-btn, .forward-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 35rpx;
  background: rgba(255, 255, 255, 0.1);
}

.rewind-text, .forward-text {
  font-size: 22rpx;
  color: #fff;
}

.play-pause-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #E85D00;
  box-shadow: 0 4rpx 20rpx rgba(232, 93, 0, 0.4);
}

.play-pause-btn .play-icon-cs {
  width: 0;
  height: 0;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #fff;
  border-radius: 4rpx;
  margin-left: 8rpx;
}

.play-pause-btn .pause-icon-cs {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.play-pause-btn .pause-bar-cs {
  width: 8rpx;
  height: 28rpx;
  background: #fff;
  border-radius: 4rpx;
}

/* 功能按钮行 */
.func-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 50rpx;
  padding: 50rpx 0;
}

.func-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
}

.mode-icon {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: bold;
}

/* 播放控制面板播放列表图标，gap为8rpx */
.player-container .playlist-icon {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.player-container .list-bar {
  width: 40rpx;
  height: 5rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 1rpx;
}

.func-btn .speed-text {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 600;
}

.sort-text {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.7);
}

.favorite-btn.favorited .favorite-icon {
  color: #FF6B00;
}

.favorite-icon {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 倍速控制 */
.speed-control {
  padding: 30rpx 0 60rpx;
}

.speed-track-wrap {
  position: relative;
  width: 100%;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.speed-track-wrap .speed-mark {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.6);
  z-index: 1;
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}

.speed-track-wrap .speed-mark.active {
  color: transparent;
}

.speed-indicator {
  position: absolute;
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(180deg, #FF6B00 0%, #FF8C42 100%);
  border-radius: 45rpx;
  top: 15rpx;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(255, 107, 0, 0.6), 0 0 40rpx rgba(255, 140, 66, 0.3);
}

.speed-indicator-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

/* 下一条信息 */
.next-info {
  padding: 20rpx 0;
  display: flex;
  justify-content: flex-start;
  padding-left: 80rpx;
}

.next-info-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.next-info-seq {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.next-info-sep {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 8rpx;
  flex-shrink: 0;
}

.next-info-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}