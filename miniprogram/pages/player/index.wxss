/* player/index.wxss */

.player-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 动画 */
.slide-up {
  animation: slideUp 0.3s ease forwards;
}

.slide-down {
  animation: slideDown 0.3s ease forwards;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slideDown {
  from {
    transform: translateY(0);
    opacity: 1;
  }
  to {
    transform: translateY(100%);
    opacity: 0;
  }
}

/* 收起按钮 */
.header-area {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.collapse-icon {
  width: 40rpx;
  height: 20rpx;
  border-left: 4rpx solid #fff;
  border-right: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  border-radius: 0 0 10rpx 10rpx;
}

/* 课程信息 */
.course-info {
  display: flex;
  align-items: center;
  padding: 40rpx 0;
  margin-top: 20rpx;
}

.course-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 4rpx solid rgba(255, 107, 0, 0.3);
}

.course-cover.rotating {
  animation: rotate 8s linear infinite;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.course-details {
  flex: 1;
  margin-left: 30rpx;
}

.course-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.course-author {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 12rpx;
}

.course-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* 播放控制面板 */
.control-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40rpx 0;
}

/* 进度条 */
.progress-row {
  padding: 20rpx 0;
}

.progress-slider {
  width: 100%;
}

.time-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0 30rpx;
}

.current-time {
  font-size: 26rpx;
  color: #fff;
}

.remaining-time {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 播放控制按钮 */
.play-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30rpx;
  padding: 30rpx 0;
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.prev-btn, .next-btn {
  width: 60rpx;
  height: 60rpx;
}

.prev-icon {
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
  margin-right: 6rpx;
}

.next-icon {
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-135deg);
  margin-left: 6rpx;
}

.rewind-btn, .forward-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 35rpx;
  background: rgba(255, 255, 255, 0.1);
}

.rewind-text, .forward-text {
  font-size: 22rpx;
  color: #fff;
}

.play-pause-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #FF6B00;
}

.play-icon {
  width: 32rpx;
  height: 32rpx;
  border-left: 20rpx solid #fff;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  margin-left: 10rpx;
}

.pause-icon {
  display: flex;
  gap: 12rpx;
}

.pause-bar {
  width: 8rpx;
  height: 36rpx;
  background: #fff;
}

/* 功能按钮行 */
.func-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 40rpx;
  padding: 40rpx 0;
}

.func-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
}

.mode-icon {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.playlist-icon {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.list-bar {
  width: 30rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.7);
}

.speed-text {
  font-size: 26rpx;
  color: #FF6B00;
  font-weight: 600;
}

.sort-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.favorite-btn.favorited .favorite-icon {
  color: #FF6B00;
}

.favorite-icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 倍速控制 */
.speed-control {
  padding: 20rpx 0 40rpx;
}

.speed-slider-container {
  width: 100%;
}

.speed-marks {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx;
}

.speed-mark {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 10rpx 20rpx;
}

.speed-mark.active {
  color: #FF6B00;
  font-weight: 600;
}

.speed-track {
  width: 100%;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 3rpx;
  margin-top: 20rpx;
  position: relative;
}

.speed-indicator {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: #FF6B00;
  border-radius: 10rpx;
  top: -7rpx;
  transform: translateX(-50%);
}