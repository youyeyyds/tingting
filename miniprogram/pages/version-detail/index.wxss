/* version-detail/index.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 固定顶部 */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

/* 状态栏占位 */
.status-bar {
  background: #fff;
}

/* 标题栏 */
.title-bar {
  display: flex;
  align-items: center;
  background: #fff;
  position: relative;
}

.title-text {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 44rpx;
  height: 44rpx;
}

.content {
  flex: 1;
  padding: 40rpx 30rpx;
}

.version-detail {
  background: #fff;
}

.detail-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 40rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.detail-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.detail-desc {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 30rpx;
}

.description {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-line;
}
