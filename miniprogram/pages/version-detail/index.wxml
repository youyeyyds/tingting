<!--version-detail/index.wxml-->
<view class="page-container">
  <!-- 固定顶部区域 -->
  <view class="header-fixed">
    <!-- 状态栏占位 -->
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
    <!-- 标题栏 -->
    <view class="title-bar" style="height: {{navBarHeight}}px;">
      <view class="back-btn" bindtap="onBack">
        <image class="back-icon" src="/icons/svg/arrow-left-black.svg" mode="aspectFit" />
      </view>
      <text class="title-text">版本介绍</text>
    </view>
  </view>

  <view class="content" style="margin-top: {{headerHeight}}px;">
    <view class="version-detail">
      <view class="detail-header">
        <text class="detail-title">{{title}}</text>
        <text class="detail-date">{{publishDate}}</text>
      </view>
      <view class="detail-desc">
        <text class="description">{{description}}</text>
      </view>
    </view>
  </view>
</view>
