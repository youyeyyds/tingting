<view class="page-container">
  <!-- 自定义导航栏 - 浅色主题，与个人页一致 -->
  <custom-navbar showBack="{{true}}" title="卡牌" />

  <!-- 内容区域 -->
  <view class="content" style="margin-top: {{headerHeight}}px;">
    <!-- 卡牌内容 -->
    <view wx:if="{{!loading}}" class="card-wrapper">
      <!-- 卡牌翻转区域 -->
      <view class="card-flip {{isFlipped ? 'flipped' : ''}} {{cardAnimation}}" bindtap="onCardTap">
        <!-- 正面 - 卡面图片 -->
        <view class="card-face card-front">
          <image class="card-image" src="{{currentCard.image}}" mode="aspectFit" bindload="onImageLoad" binderror="onImageError" />
        </view>
        <!-- 背面 - 台词 -->
        <view class="card-face card-back" style="background-image: url({{defaultCardFace}});">
          <text class="card-quote">{{currentCard.quote}}</text>
        </view>
      </view>
    </view>

    <!-- 导航按钮 -->
    <view class="nav-buttons">
      <view class="nav-btn {{!loading && currentIndex <= 0 ? 'disabled' : ''}}" bindtap="onPrev">
        <text class="nav-arrow">‹</text>
      </view>
      <view class="card-indicator">
        <text class="indicator-text">{{loading ? ' / ' : (currentIndex + 1) + ' / ' + cards.length}}</text>
      </view>
      <view class="nav-btn {{!loading && currentIndex >= cards.length - 1 ? 'disabled' : ''}}" bindtap="onNext">
        <text class="nav-arrow">›</text>
      </view>
    </view>
  </view>
</view>
