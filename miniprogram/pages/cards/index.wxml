<view class="page-container">
  <!-- 自定义导航栏 - 透明背景白色图标 -->
  <custom-navbar showBack="{{true}}" title="卡牌" iconColor="white" titleColor="white" transparent />

  <!-- 内容区域 -->
  <view class="content" style="margin-top: {{headerHeight}}px;">
    <!-- 骨架屏 - 加载中 -->
    <view wx:if="{{loading}}" class="skeleton-container">
      <view class="skeleton-card"></view>
    </view>

    <!-- 卡牌内容 -->
    <view wx:else class="card-wrapper">
      <!-- 卡牌翻转区域 -->
      <view class="card-flip {{isFlipped ? 'flipped' : ''}}" bindtap="onCardTap">
        <!-- 正面 - 卡面图片 -->
        <view class="card-face card-front">
          <image class="card-image" src="{{currentCard.image}}" mode="aspectFit" bindload="onImageLoad" binderror="onImageError" />
        </view>
        <!-- 背面 - 台词 -->
        <view class="card-face card-back">
          <text class="card-quote">{{currentCard.quote}}</text>
        </view>
      </view>
    </view>

    <!-- 导航按钮 -->
    <view class="nav-buttons">
      <view class="nav-btn {{currentIndex <= 0 ? 'disabled' : ''}}" bindtap="onPrev">
        <text class="nav-arrow">‹</text>
      </view>
      <view class="card-indicator">
        <text class="indicator-text">{{currentIndex + 1}} / {{cards.length}}</text>
      </view>
      <view class="nav-btn {{currentIndex >= cards.length - 1 ? 'disabled' : ''}}" bindtap="onNext">
        <text class="nav-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 迷你播放器 -->
  <mini-player id="miniPlayer" />
</view>