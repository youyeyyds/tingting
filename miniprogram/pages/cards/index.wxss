/* cards/index.wxss */
.page-container {
  height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
}

/* 骨架屏 */
.skeleton-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  flex: 1;
}

.skeleton-card {
  width: 500rpx;
  height: 700rpx;
  background: linear-gradient(90deg, #2a2a4a 25%, #3a3a5a 50%, #2a2a4a 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 20rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 卡牌容器 */
.card-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  flex: 1;
}

/* 翻转卡片 */
.card-flip {
  width: 100%;
  height: 100%;
  perspective: 1000rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
}

.card-flip.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-front {
  background: #fff;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-back {
  background: linear-gradient(135deg, #2c3e50 0%, #1a252f 100%);
  background-size: cover;
  background-position: center;
  transform: rotateY(180deg);
}

.card-back::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: inherit;
  background-size: cover;
  background-position: center;
  filter: brightness(0.4);
  z-index: 0;
}

.card-quote {
  font-size: 36rpx;
  color: #fff;
  line-height: 1.6;
  text-align: left;
  word-break: break-all;
  position: relative;
  z-index: 1;
}

/* 导航按钮 */
.nav-buttons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
  padding: 20rpx 0;
  padding-bottom: env(safe-area-inset-bottom, 0);
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn.disabled {
  opacity: 0.3;
}

.nav-arrow {
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
}

.card-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  text-align: center;
}

.indicator-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}