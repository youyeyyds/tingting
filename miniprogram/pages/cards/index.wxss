/* cards/index.wxss */
.page-container {
  height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  /* 留出画框外边距：左右 30rpx，上 20rpx，下 10rpx（底部按钮区会占空间） */
  padding: 20rpx 30rpx 10rpx;
  box-sizing: border-box;
}

/* 骨架屏 */
.skeleton-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  flex: 1;
}

.skeleton-card {
  width: 100%;
  height: 100%;
  background: #e8e8e8;
  border-radius: 16rpx;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

/* 卡牌"画框"：与灰色背景融合，仅靠 16rpx 圆角 + overflow 裁剪图片边缘 */
.card-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  flex: 1;
  border-radius: 16rpx;
  padding: 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* 翻转卡片 */
.card-flip {
  width: 100%;
  height: 100%;
  perspective: 1000rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
}

.card-flip.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.card-front {
  background: transparent;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-back {
  background: linear-gradient(135deg, #fafafa 0%, #f0f0f0 100%);
  background-size: cover;
  background-position: center;
  transform: rotateY(180deg);
  padding: 40rpx;
  box-sizing: border-box;
}

.card-back::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: inherit;
  background-size: cover;
  background-position: center;
  filter: brightness(0.95);
  z-index: 0;
}

.card-quote {
  font-size: 36rpx;
  color: #333;
  line-height: 1.6;
  text-align: left;
  word-break: break-all;
  position: relative;
  z-index: 1;
}

/* 卡牌切换动画 */
.card-flip.left-out {
  animation: leftOut 0.3s ease forwards;
}

.card-flip.right-in {
  animation: rightIn 0.3s ease forwards;
}

.card-flip.right-out {
  animation: rightOut 0.3s ease forwards;
}

.card-flip.left-in {
  animation: leftIn 0.3s ease forwards;
}

@keyframes leftOut {
  from { transform: translateX(0) scale(1); opacity: 1; }
  to { transform: translateX(-150%) scale(0.8); opacity: 0; }
}
@keyframes rightIn {
  from { transform: translateX(150%) scale(0.8); opacity: 0; }
  to { transform: translateX(0) scale(1); opacity: 1; }
}
@keyframes rightOut {
  from { transform: translateX(0) scale(1); opacity: 1; }
  to { transform: translateX(150%) scale(0.8); opacity: 0; }
}
@keyframes leftIn {
  from { transform: translateX(-150%) scale(0.8); opacity: 0; }
  to { transform: translateX(0) scale(1); opacity: 1; }
}

/* 底部按钮 */
.nav-buttons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
  padding: 20rpx 0 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom, 0));
  background: #f5f5f5;
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 25rpx;
}

.nav-btn.disabled {
  opacity: 0.3;
}

.nav-arrow {
  font-size: 60rpx;
  color: #999;
  line-height: 1;
  font-weight: 300;
}

.card-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  text-align: center;
}

.indicator-text {
  font-size: 32rpx;
  color: #999;
}
