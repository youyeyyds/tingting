/* cards/index.wxss */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
}

/* 骨架屏 */
.skeleton-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.skeleton-card {
  width: 500rpx;
  height: 700rpx;
  background: linear-gradient(90deg, #2a2a4a 25%, #3a3a5a 50%, #2a2a4a 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 20rpx;
}

.skeleton-nav {
  display: flex;
  align-items: center;
  gap: 80rpx;
  margin-top: 60rpx;
}

.skeleton-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(90deg, #2a2a4a 25%, #3a3a5a 50%, #2a2a4a 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 40rpx;
}

.skeleton-indicator {
  width: 120rpx;
  height: 40rpx;
  background: linear-gradient(90deg, #2a2a4a 25%, #3a3a5a 50%, #2a2a4a 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 卡牌容器 */
.card-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

/* 翻转卡片 */
.card-flip {
  width: 500rpx;
  height: 700rpx;
  perspective: 1000rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
}

.card-flip.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

.card-front {
  background: #fff;
}

.card-image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.card-back {
  background: linear-gradient(135deg, #2c3e50 0%, #1a252f 100%);
  transform: rotateY(180deg);
  padding: 40rpx;
}

.card-quote {
  font-size: 36rpx;
  color: #fff;
  line-height: 1.6;
  text-align: left;
  word-break: break-all;
}

/* 导航按钮 */
.nav-buttons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
  margin-top: 60rpx;
  padding-bottom: 100rpx;
}

.nav-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn.disabled {
  opacity: 0.3;
}

.nav-arrow {
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
}

.card-indicator {
  min-width: 120rpx;
  text-align: center;
}

.indicator-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}