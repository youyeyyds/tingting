<!--favorite/index.wxml-->
<view class="page-container">
  <!-- 固定顶部区域 -->
  <view class="header-fixed">
    <!-- 状态栏占位 -->
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
    <!-- 标题栏 -->
    <view class="title-bar" style="height: {{navBarHeight}}px;">
      <view class="back-btn" bindtap="onBack">
        <image class="back-icon" src="/icons/svg/arrow-left-black.svg" mode="aspectFit" />
      </view>
      <text class="title-text">收藏</text>
    </view>
  </view>

  <!-- 内容区域，使用原生页面滚动 -->
  <view class="content" style="margin-top: {{headerHeight}}px; height: {{scrollHeight}}px;">
    <!-- 头条轮播 -->
    <swiper class="banner" indicator-dots="{{headlines.length > 1}}" autoplay="{{true}}" interval="{{bannerSpeed}}" circular="{{true}}" wx:if="{{headlines.length > 0}}">
      <swiper-item wx:for="{{headlines}}" wx:key="_id">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
    <!-- 横幅占位 -->
    <view class="banner-placeholder" wx:else></view>

    <!-- 未登录状态 -->
    <view class="empty-tip" wx:if="{{!isLoggedIn}}" style="{{headlines.length > 0 ? 'margin-top: 40rpx;' : ''}}">
      <text class="empty-text">请先登录查看收藏</text>
      <button class="login-btn" bindtap="handleLogin">登录</button>
    </view>

    <!-- 已登录但加载中 -->
    <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this" wx:if="{{isLoggedIn && loading}}" style="{{headlines.length > 0 ? 'margin-top: 40rpx;' : ''}}">
      <view class="skeleton-image"></view>
      <view class="skeleton-info">
        <view class="skeleton-title"></view>
        <view class="skeleton-author"></view>
        <view class="skeleton-meta"></view>
      </view>
    </view>

    <!-- 已登录但无收藏 -->
    <view class="empty-tip" wx:if="{{isLoggedIn && favoriteChapters.length === 0 && !loading}}" style="{{headlines.length > 0 ? 'margin-top: 40rpx;' : ''}}">
      <text class="empty-text">随时随地，学习成长</text>
    </view>

    <!-- 收藏列表 -->
    <view class="favorite-list" wx:if="{{isLoggedIn && favoriteChapters.length > 0}}">
      <view class="chapter-card" wx:for="{{favoriteChapters}}" wx:key="_id"
        data-index="{{index}}" bindtap="onChapterTap">
        <!-- 第一行：圆形封面 + 标题（作者·课程名）+ 跳转按钮 + 分隔线 -->
        <view class="chapter-header">
          <image class="chapter-cover" src="{{item.courseCover || '/icons/svg/course.svg'}}" mode="aspectFill" />
          <view class="chapter-title-row" catchtap="onCourseTap" data-id="{{item.course}}">
            <text class="chapter-author">{{item.author || '未知作者'}}</text>
            <text class="chapter-sep-top">·</text>
            <text class="chapter-course">{{item.courseTitle || '未知课程'}}</text>
            <view class="course-arrow"></view>
          </view>
        </view>
        <view class="info-divider"></view>
        <!-- 第二行：序号 | 章节名称 -->
        <view class="chapter-title-line {{item.isPlaying ? 'playing' : ''}}">
          <text class="chapter-seq" wx:if="{{item.seq > 0}}">{{item.seq}}</text>
          <text class="chapter-sep" wx:if="{{item.seq > 0}}">|</text>
          <text class="chapter-name">{{item.title}}</text>
        </view>
        <!-- 第三行：时长 | 学习进度 + 操作按钮 -->
        <view class="chapter-footer">
          <view class="chapter-meta">
            <text class="chapter-duration">{{item.durationText}}</text>
            <text class="chapter-sep-meta">|</text>
            <text class="chapter-progress">{{item.progressText}}</text>
          </view>
          <view class="chapter-actions">
            <block wx:if="{{item.isPlaying}}">
              <view class="audio-icon playing" data-id="{{item._id}}" catchtap="onChapterTap" data-index="{{index}}">
                <view class="audio-bar audio-bar-1"></view>
                <view class="audio-bar audio-bar-2"></view>
                <view class="audio-bar audio-bar-3"></view>
              </view>
            </block>
            <block wx:else>
              <view class="play-btn" catchtap="onChapterTap" data-index="{{index}}">
                <view class="play-triangle"></view>
              </view>
            </block>
            <view class="close-btn" catchtap="onRemoveTap" data-id="{{item._id}}" data-index="{{index}}">
              <text class="close-text">×</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 0 ? '/icons/svg/home-active.svg' : '/icons/svg/home.svg'}}" mode="aspectFit" />
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 1 ? '/icons/svg/favorite-active.svg' : '/icons/svg/favorite.svg'}}" mode="aspectFit" />
      <text class="tab-text">收藏</text>
    </view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" data-index="2" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 2 ? '/icons/svg/mine-active.svg' : '/icons/svg/mine.svg'}}" mode="aspectFit" />
      <text class="tab-text">我的</text>
    </view>
  </view>

  <!-- 迷你播放器 -->
  <mini-player id="miniPlayer" />
</view>