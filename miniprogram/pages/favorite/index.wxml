<!--favorite/index.wxml-->
<view class="page-container">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="header" style="height: {{navBarHeight}}px;">
    <text class="header-title">收藏</text>
  </view>

  <scroll-view class="content" scroll-y="true" enhanced="true"
    refresher-enabled="{{true}}" refresher-triggered="{{refresherTriggered}}" refresher-threshold="{{80}}" bindrefresherrefresh="onRefresh">
    <!-- 头条轮播 -->
    <swiper class="banner" indicator-dots="{{headlines.length > 1}}" autoplay="{{true}}" interval="{{3000}}" circular="{{true}}" wx:if="{{headlines.length > 0}}">
      <swiper-item wx:for="{{headlines}}" wx:key="_id">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
    </swiper>

    <!-- 未登录状态 -->
    <view class="empty-state" wx:if="{{!isLoggedIn}}" style="{{headlines.length > 0 ? 'margin-top: 40rpx;' : ''}}">
      <image class="empty-icon" src="/icons/svg/favorite.svg" mode="aspectFit" />
      <text class="empty-text">请先登录查看收藏</text>
      <button class="login-btn" bindtap="handleLogin">登录</button>
    </view>

    <!-- 已登录但无收藏 -->
    <view class="empty-state" wx:if="{{isLoggedIn && !loading && favoriteChapters.length === 0}}">
      <image class="empty-icon" src="/icons/svg/favorite.svg" mode="aspectFit" />
      <text class="empty-text">暂无收藏章节</text>
    </view>

    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{isLoggedIn && loading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 收藏列表 -->
    <view class="favorite-list" wx:if="{{isLoggedIn && !loading && favoriteChapters.length > 0}}">
      <view class="chapter-card" wx:for="{{favoriteChapters}}" wx:key="_id"
        data-id="{{item._id}}" data-course="{{item.course}}" bindtap="onChapterTap">
        <image class="chapter-cover" src="{{item.courseCover || '/icons/svg/course.svg'}}" mode="aspectFill" />
        <view class="chapter-info">
          <text class="chapter-title">{{item.title}}</text>
          <text class="chapter-course">{{item.courseTitle}}</text>
          <view class="chapter-meta">
            <text class="chapter-duration">{{item.durationText}}</text>
            <text class="chapter-progress">{{item.progressText}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 0 ? '/icons/svg/home-active.svg' : '/icons/svg/home.svg'}}" mode="aspectFit" />
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 1 ? '/icons/svg/favorite-active.svg' : '/icons/svg/favorite.svg'}}" mode="aspectFit" />
      <text class="tab-text">收藏</text>
    </view>
    <view class="tab-item {{activeTab === 2 ? 'active' : ''}}" data-index="2" bindtap="onTabChange">
      <image class="tab-icon" src="{{activeTab === 2 ? '/icons/svg/mine-active.svg' : '/icons/svg/mine.svg'}}" mode="aspectFit" />
      <text class="tab-text">我的</text>
    </view>
  </view>

  <!-- 迷你播放器 -->
  <mini-player id="miniPlayer" />
</view>