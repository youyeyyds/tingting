/* favorite/index.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 固定顶部 */
.header-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

/* 状态栏占位 */
.status-bar {
  background: #fff;
}

/* 标题栏 */
.title-bar {
  display: flex;
  align-items: center;
  background: #fff;
  position: relative;
}

.title-text {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
}

.back-btn {
  position: absolute;
  left: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 44rpx;
  height: 44rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom, 0));
  overflow-y: auto;
}

/* 头条轮播 */
.banner {
  width: 100%;
  height: 280rpx;
}

.banner-placeholder {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #ddd;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}

/* 登录按钮 */
.login-btn {
  margin-top: 20rpx;
  padding: 16rpx 60rpx;
  background: #FF6B00;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

/* 收藏列表 */
.favorite-list {
  display: flex;
  flex-direction: column;
  padding: 20rpx 30rpx 0;
}

.chapter-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 第一行：圆形封面 + 标题 + 分隔线 */
.chapter-header {
  display: flex;
  align-items: center;
}

.chapter-cover {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #ddd;
  flex-shrink: 0;
}

.chapter-title-row {
  flex: 1;
  display: flex;
  align-items: center;
  margin-left: 16rpx;
  min-width: 0;
}

.chapter-author {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.chapter-sep-top {
  font-size: 28rpx;
  color: #ccc;
  margin: 0 8rpx;
}

.chapter-course {
  font-size: 28rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.course-arrow {
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid #999;
  border-bottom: 3rpx solid #999;
  transform: rotate(-135deg);
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 分隔线 */
.info-divider {
  height: 1rpx;
  background: #ddd;
  margin: 24rpx 0;
}

/* 第二行：序号 | 章节名称 */
.chapter-title-line {
  display: flex;
  align-items: flex-start;
}

.chapter-seq {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  flex-shrink: 0;
}

.chapter-title-line.playing .chapter-seq,
.chapter-title-line.playing .chapter-sep,
.chapter-title-line.playing .chapter-name {
  color: #FF6B00;
}

.chapter-sep {
  font-size: 30rpx;
  color: #333;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.chapter-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
  flex: 1;
}

/* 第三行：时长 | 进度 + 操作按钮 */
.chapter-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.chapter-meta {
  display: flex;
  align-items: center;
}

.chapter-duration {
  font-size: 26rpx;
  color: #999;
}

.chapter-sep-meta {
  font-size: 26rpx;
  color: #ccc;
  margin: 0 8rpx;
}

.chapter-progress {
  font-size: 26rpx;
  color: #999;
}

/* 操作按钮 */
.chapter-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.play-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  background: #FF6B00;
  border-radius: 12rpx;
}

.play-triangle {
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 12rpx solid #fff;
}

.close-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.close-text {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

/* 骨架屏 */
.skeleton-card {
  width: 690rpx;
  display: flex;
  padding: 20rpx;
  margin: 0 auto 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.skeleton-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.skeleton-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.skeleton-title {
  height: 32rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

.skeleton-author {
  height: 26rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

.skeleton-meta {
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
}

/* 音频动画 */
.audio-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  width: 40rpx;
  height: 40rpx;
}

.audio-bar {
  width: 4rpx;
  height: 16rpx;
  background: #999;
  border-radius: 2rpx;
}

.audio-bar-1 { height: 12rpx; }
.audio-bar-2 { height: 20rpx; }
.audio-bar-3 { height: 16rpx; }

.audio-icon.playing .audio-bar {
  background: #FF6B00;
  animation: audioWave 0.5s ease-in-out infinite alternate;
}

.audio-icon.playing .audio-bar-1 { animation-delay: 0s; }
.audio-icon.playing .audio-bar-2 { animation-delay: 0.2s; }
.audio-icon.playing .audio-bar-3 { animation-delay: 0.4s; }

@keyframes audioWave {
  from { height: 8rpx; }
  to { height: 24rpx; }
}