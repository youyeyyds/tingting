/* favorite/index.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 状态栏占位 */
.status-bar {
  background: #fff;
}

/* 标题栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.header-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-bottom: 100rpx;
}

/* 头条轮播 */
.banner {
  width: 100%;
  height: 200rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}

/* 登录按钮 */
.login-btn {
  margin-top: 20rpx;
  padding: 16rpx 60rpx;
  background: #FF6B00;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 收藏列表 */
.favorite-list {
  width: 100%;
  padding: 20rpx;
}

.chapter-card {
  display: flex;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.chapter-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  background: #eee;
}

.chapter-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
}

.chapter-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.chapter-course {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.chapter-meta {
  display: flex;
  margin-top: 10rpx;
}

.chapter-duration {
  font-size: 22rpx;
  color: #666;
}

.chapter-progress {
  font-size: 22rpx;
  color: #FF6B00;
  margin-left: 16rpx;
}