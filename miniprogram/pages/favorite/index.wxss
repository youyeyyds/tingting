/* favorite/index.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 状态栏占位 */
.status-bar {
  background: #fff;
}

/* 标题栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.header-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-bottom: 100rpx;
}

/* 头条轮播 */
.banner {
  width: 100%;
  height: 280rpx;
}

.banner-placeholder {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

/* 底部导航栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.tab-item.active .tab-text {
  color: #FF6B00;
}

/* 登录按钮 */
.login-btn {
  margin-top: 20rpx;
  padding: 16rpx 60rpx;
  background: #FF6B00;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

/* 收藏列表 */
.favorite-list {
  display: flex;
  flex-direction: column;
  padding: 20rpx 30rpx 0;
}

.chapter-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  position: relative;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 左边封面 */
.chapter-cover-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #eee;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chapter-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
}

/* 右边信息 */
.chapter-info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

/* 第一行：作者 · 课程名称 */
.chapter-top-line {
  display: flex;
  align-items: center;
  padding: 4rpx 0;
}

.chapter-author {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.chapter-sep-top {
  font-size: 26rpx;
  color: #ccc;
  margin: 0 6rpx;
}

.chapter-course {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.course-arrow {
  width: 12rpx;
  height: 12rpx;
  border-left: 2rpx solid #999;
  border-bottom: 2rpx solid #999;
  transform: rotate(-135deg);
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 分隔线 */
.info-divider {
  height: 1rpx;
  background: #eee;
  margin: 16rpx 0;
}

/* 第二行：序号 | 章节名称 */
.chapter-title-line {
  display: flex;
  align-items: flex-start;
}

.chapter-seq {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  flex-shrink: 0;
}

.chapter-title-line.playing .chapter-seq,
.chapter-title-line.playing .chapter-sep,
.chapter-title-line.playing .chapter-name {
  color: #FF6B00;
}

.chapter-sep {
  font-size: 30rpx;
  color: #333;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.chapter-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
  flex: 1;
}

/* 第三行：时长 | 进度 */
.chapter-meta-line {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.chapter-duration {
  font-size: 26rpx;
  color: #999;
}

.chapter-sep-meta {
  font-size: 26rpx;
  color: #ccc;
  margin: 0 8rpx;
}

.chapter-progress {
  font-size: 26rpx;
  color: #999;
}

/* 右下角操作按钮 */
.chapter-actions {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.play-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  background: #FF6B00;
  border-radius: 12rpx;
}

.play-triangle {
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 12rpx solid #fff;
}

.close-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.close-text {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}